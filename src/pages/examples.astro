---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import MaxonCode from '../components/MaxonCode.astro';

// Real, compilable programs imported verbatim from the compiler repo's examples/
// directory (copied into src/examples). The ?raw import keeps them byte-accurate.
import spectralNorm from '../examples/spectral-norm.maxon?raw';
import nbody from '../examples/nbody.maxon?raw';
import fannkuch from '../examples/fannkuch-redux.maxon?raw';

const examples = [
  {
    file: 'spectral-norm.maxon',
    title: 'Spectral norm',
    blurb:
      "Computes the largest eigenvalue of an infinite matrix with the power method. Shows ranged type aliases, try … otherwise inside hot loops, and labeled nesting.",
    code: spectralNorm,
  },
  {
    file: 'nbody.maxon',
    title: 'N-body simulation',
    blurb:
      'A classic gravitational simulation of the outer solar system. Shows struct types with methods, static constructors, and named arguments.',
    code: nbody,
  },
  {
    file: 'fannkuch-redux.maxon',
    title: 'Fannkuch-redux',
    blurb:
      'Generates every permutation of an array and counts pancake flips. Shows array manipulation and integer-heavy control flow.',
    code: fannkuch,
  },
];
---

<MarketingLayout
  title="Examples — Maxon"
  description="Real, compilable Maxon programs: a spectral-norm computation, an N-body simulation, and the fannkuch-redux benchmark."
  path="/examples/"
>
  <section class="mx-auto max-w-4xl px-5 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Examples</h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-slate-300">
      These are complete, compilable programs straight from the Maxon repository — the same
      files you can run with <code class="rounded bg-ink-800 px-1.5 py-0.5 font-mono text-sm text-brand-300">./bin/maxon</code>.
      Each one leans on a different part of the language.
    </p>

    <div class="mt-12 space-y-16">
      {
        examples.map((ex) => (
          <article>
            <h2 class="text-xl font-bold text-white">{ex.title}</h2>
            <p class="mt-2 max-w-2xl text-slate-400">{ex.blurb}</p>
            <div class="mt-4">
              <MaxonCode code={ex.code} title={ex.file} />
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-16 rounded-xl border border-ink-700 bg-ink-950/60 p-6">
      <p class="text-slate-300">
        Want to walk through the language step by step instead?
        <a class="font-semibold text-brand-300 hover:text-brand" href="/docs/getting-started/first-program/">
          Start with your first program →
        </a>
      </p>
    </div>
  </section>
</MarketingLayout>
