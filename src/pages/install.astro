---
import MarketingLayout from '../layouts/MarketingLayout.astro';

// Prebuilt downloads are published as GitHub Release assets on the compiler repo.
// To wire up a real release: set `released` to true and update `version` + the
// `asset` filenames to match what you upload to the release. `latest/download`
// always resolves to the newest release, so the links keep working across versions.
const RELEASES = 'https://github.com/maxon-lang/maxon/releases';
const released = false; // flip to true once the first release with binaries is published
const version = 'v0.1.0';

const downloads = [
  {
    os: 'Windows',
    arch: 'x64',
    asset: 'maxon-windows-x64.zip',
    note: 'Windows 10/11, 64-bit',
  },
  {
    os: 'Linux',
    arch: 'x64',
    asset: 'maxon-linux-x64.tar.gz',
    note: 'glibc, 64-bit',
  },
];

const assetUrl = (asset: string) => `${RELEASES}/latest/download/${asset}`;
---

<MarketingLayout
  title="Install Maxon"
  description="Build the Maxon compiler from source with the .NET SDK, set up the VS Code extension, and compile your first program."
  path="/install/"
>
  <section class="mx-auto max-w-3xl px-5 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Install Maxon</h1>
    <p class="mt-4 text-lg leading-relaxed text-slate-300">
      Download a prebuilt release for your platform, or build the compiler from source. Either
      way you'll end up with the <code class="font-mono text-brand-300">maxon</code> toolchain —
      compiler, language server, and VS Code extension.
    </p>

    <!-- Download -->
    <h2 class="mt-12 text-2xl font-bold text-white">Download</h2>
    {
      released ? (
        <>
          <p class="mt-3 text-slate-300">
            Prebuilt binaries for the latest release ({version}). Unpack the archive and put the{' '}
            <code class="font-mono text-brand-300">bin/</code> directory on your{' '}
            <code class="font-mono text-brand-300">PATH</code>.
          </p>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            {downloads.map((d) => (
              <a
                href={assetUrl(d.asset)}
                class="group flex items-center justify-between rounded-xl border border-ink-700 bg-ink-950/50 p-5 transition-colors hover:border-brand/50"
              >
                <span>
                  <span class="block font-semibold text-white">
                    {d.os} <span class="text-slate-500">·</span>{' '}
                    <span class="font-mono text-sm text-brand-300">{d.arch}</span>
                  </span>
                  <span class="mt-1 block text-xs text-slate-500">{d.note}</span>
                </span>
                <span class="ml-4 rounded-lg bg-brand px-4 py-2 text-sm font-semibold text-ink-950 transition-colors group-hover:bg-brand-400">
                  Download
                </span>
              </a>
            ))}
          </div>
          <p class="mt-4 text-sm text-slate-400">
            Looking for another platform or an older version? See{' '}
            <a class="text-brand-300 hover:text-brand" href={RELEASES} target="_blank" rel="noopener">
              all releases on GitHub
            </a>
            .
          </p>
        </>
      ) : (
        <div class="mt-3 rounded-xl border border-ink-700 bg-ink-950/50 p-6">
          <p class="text-slate-300">
            Prebuilt binaries aren't published yet. For now, build from source with the steps
            below — it takes a couple of commands. When releases are available they'll appear on{' '}
            <a class="text-brand-300 hover:text-brand" href={RELEASES} target="_blank" rel="noopener">
              the GitHub releases page
            </a>
            .
          </p>
        </div>
      )
    }

    <!-- Build from source -->
    <h2 class="mt-12 text-2xl font-bold text-white">Build from source</h2>
    <p class="mt-3 text-slate-300">
      Maxon currently ships with the C# compiler (<code class="font-mono text-brand-300">maxon-sharp</code>),
      which builds with the .NET SDK and produces a native-code-generating
      <code class="font-mono text-brand-300">maxon</code> binary. Building it takes one command.
    </p>

    <!-- Prerequisites -->
    <h3 class="mt-8 text-xl font-bold text-white">1. Prerequisites</h3>

    <ul class="mt-4 space-y-2 text-slate-300">
      <li class="flex gap-3">
        <span class="text-brand">›</span>
        <span>
          <a class="text-brand-300 hover:text-brand" href="https://dotnet.microsoft.com/download" target="_blank" rel="noopener">.NET 10 SDK</a>
          — the compiler targets <code class="font-mono text-brand-300">net10.0</code>.
        </span>
      </li>
      <li class="flex gap-3"><span class="text-brand">›</span> Git</li>
      <li class="flex gap-3"><span class="text-brand">›</span> Node.js 20+ <span class="text-slate-500">— only needed to build the VS Code extension</span></li>
    </ul>

    <!-- Clone & build -->
    <h3 class="mt-8 text-xl font-bold text-white">2. Clone and build</h3>
    <p class="mt-3 text-slate-300">
      Clone the repository and build the compiler with <code class="font-mono text-brand-300">dotnet</code>.
      The build copies the resulting binary to <code class="font-mono text-brand-300">bin/maxon</code>.
    </p>
    <div class="mt-4 overflow-hidden rounded-xl border border-ink-700 bg-ink-950/80">
      <div class="flex items-center gap-2 border-b border-ink-700 px-4 py-2.5">
        <span class="h-2.5 w-2.5 rounded-full bg-ink-600"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-ink-600"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-ink-600"></span>
        <span class="ml-2 font-mono text-xs text-slate-500">terminal</span>
      </div>
      <pre class="overflow-x-auto p-4 font-mono text-sm leading-relaxed text-slate-300"><span class="text-slate-500"># clone</span>
<span class="text-brand-300">git</span> clone https://github.com/maxon-lang/maxon.git
<span class="text-brand-300">cd</span> maxon

<span class="text-slate-500"># build the compiler -> bin/maxon</span>
<span class="text-brand-300">dotnet</span> build maxon-sharp</pre>
    </div>

    <p class="mt-4 text-sm text-slate-400">
      On Windows, <code class="font-mono text-brand-300">buildall.bat</code> builds and tests the
      full toolchain end to end — the C# compiler, the self-hosted compiler, and their spec
      tests.
    </p>

    <!-- Verify -->
    <h3 class="mt-8 text-xl font-bold text-white">3. Compile your first program</h3>
    <p class="mt-3 text-slate-300">
      Compile and run one of the bundled examples to confirm the build works:
    </p>
    <div class="mt-4 overflow-hidden rounded-xl border border-ink-700 bg-ink-950/80">
      <div class="flex items-center gap-2 border-b border-ink-700 px-4 py-2.5">
        <span class="h-2.5 w-2.5 rounded-full bg-ink-600"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-ink-600"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-ink-600"></span>
        <span class="ml-2 font-mono text-xs text-slate-500">terminal</span>
      </div>
      <pre class="overflow-x-auto p-4 font-mono text-sm leading-relaxed text-slate-300"><span class="text-slate-500"># compile and run an example</span>
<span class="text-brand-300">bin/maxon</span> build examples/spectral-norm.maxon

<span class="text-slate-500"># run the full spec-test suite</span>
<span class="text-brand-300">bin/maxon</span> spec-test</pre>
    </div>
    <p class="mt-4 text-sm text-slate-400">
      The compiler produces a native executable next to your source file
      (<code class="font-mono text-brand-300">.exe</code> on Windows). See the
      <a class="text-brand-300 hover:text-brand" href="/docs/cli/">CLI reference</a> for every
      command and flag.
    </p>

    <!-- Editor -->
    <h3 class="mt-8 text-xl font-bold text-white">4. Set up your editor</h3>
    <p class="mt-3 text-slate-300">
      Maxon includes a Language Server and a VS Code extension — syntax highlighting, real-time
      diagnostics, completion, and hover. Build the extension from the
      <code class="font-mono text-brand-300">vscode-extension/</code> directory (Node.js 20+),
      then install the generated <code class="font-mono text-brand-300">.vsix</code> or load the
      extension folder directly in VS Code.
    </p>

    <div class="mt-12 rounded-xl border border-ink-700 bg-ink-950/60 p-6">
      <p class="text-slate-300">
        Built it? Head to
        <a class="font-semibold text-brand-300 hover:text-brand" href="/docs/getting-started/first-program/">
          your first program →
        </a>
      </p>
    </div>
  </section>
</MarketingLayout>
